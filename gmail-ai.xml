logs │ └────────────────────────────────────────────────────────────┘ Database schema (core — MVP) -- users (app identity) CREATE TABLE users ( id UUID PRIMARY KEY, email TEXT UNIQUE, created_at TIMESTAMPTZ DEFAULT NOW() ); -- tokens: encrypt refresh_token and sensitive fields in app CREATE TABLE gmail_connections ( user_id UUID PRIMARY KEY REFERENCES users(id), enc_refresh_token BYTEA NOT NULL, token_meta JSONB, revoked_at TIMESTAMPTZ, updated_at TIMESTAMPTZ DEFAULT NOW() ); -- optional sync state CREATE TABLE sync_state ( user_id UUID PRIMARY KEY REFERENCES users(id), last_history_id TEXT, last_synced_at TIMESTAMPTZ ); CREATE TABLE threads ( id UUID PRIMARY KEY, user_id UUID NOT NULL REFERENCES users(id), gmail_thread_id TEXT NOT NULL, last_message_at TIMESTAMPTZ, UNIQUE (user_id, gmail_thread_id) ); CREATE TABLE messages ( id UUID PRIMARY KEY, thread_id UUID NOT NULL REFERENCES threads(id) ON DELETE CASCADE, gmail_message_id TEXT NOT NULL, "from" TEXT, subject TEXT, body_text TEXT, received_at TIMESTAMPTZ, classification TEXT -- 'ok_to_reply' | 'no_response' | ... ); CREATE TABLE draft_artifacts ( id UUID PRIMARY KEY, user_id UUID NOT NULL REFERENCES users(id), thread_id UUID NOT NULL REFERENCES threads(id), model TEXT NOT NULL, -- OpenRouter model id body TEXT NOT NULL, confidence INT NOT NULL CHECK (confidence >= 0 AND confidence <= 100), status TEXT NOT NULL, -- 'ready' | 'needs_review' | 'dismissed' gmail_draft_id TEXT, -- if created in Gmail idempotency_key TEXT, created_at TIMESTAMPTZ DEFAULT NOW() ); CREATE TABLE audit_log ( id BIGSERIAL PRIMARY KEY, user_id UUID, event TEXT, details JSONB, created_at TIMESTAMPTZ DEFAULT NOW() ); (Add indexes on (user_id, gmail_thread_id), (thread_id, received_at), draft_artifacts(user_id, status).) REST API sketch (MVP) Method Path Purpose GET /health Liveness GET /auth/google Start OAuth (if you expose web) GET /auth/google/callback Code exchange, store token POST /gmail/sync Pull recent threads GET /threads List with fi