# App
APP_NAME=draftly-gmail-agent
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=*

# Database — pick one:
#
# PostgreSQL (Neon, RDS, local). Bare postgresql:// is auto-mapped to psycopg v3.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mydb?sslmode=require
#
# MySQL — URL-encode special characters in the password.
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/draftly?charset=utf8mb4
#
# SQLite — single file (persists across restarts unless the file is deleted)
DATABASE_URL=sqlite:///./draftly.db

# Google OAuth (Gmail) — create OAuth 2.0 Web client in Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must match the authorized redirect URI in Google Cloud
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback
# Frontend origin for postMessage target + /oauth-done and /oauth-cancel (must match the URL you use in the browser)
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# OpenAI — reply draft generation (leave empty to use built-in mock drafts)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Scopes (space-separated). Defaults include openid + userinfo.email + Gmail — see README
# Optional override:
# GOOGLE_SCOPES=openid https://www.googleapis.com/auth/userinfo.email https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.compose
